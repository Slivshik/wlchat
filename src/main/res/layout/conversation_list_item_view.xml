<?xml version="1.0" encoding="utf-8"?>
<org.thoughtcrime.securesms.ConversationListItem
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@drawable/ripple_list_item"
    android:layout_width="match_parent"
    android:focusable="true"
    android:layout_height="76dp"
    android:paddingLeft="12dp"
    android:paddingRight="12dp"
    android:paddingStart="12dp"
    android:paddingEnd="12dp">

    <org.thoughtcrime.securesms.components.AvatarView
        android:id="@+id/avatar"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentLeft="true"
        android:layout_centerVertical="true"
        android:importantForAccessibility="no"
        android:layout_marginEnd="12dp"
        android:layout_marginRight="12dp"
        android:transitionName="chat_avatar" />

    <LinearLayout
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_toRightOf="@id/avatar"
        android:layout_toEndOf="@id/avatar">

        <LinearLayout
            android:orientation="vertical"
            android:layout_weight="2"
            android:layout_width="0dp"
            android:layout_height="wrap_content">

            <org.thoughtcrime.securesms.components.FromTextView
                android:id="@+id/from_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="2dp"
                android:drawablePadding="6dp"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"
                android:textSize="16sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:textColor="?attr/conversation_list_item_contact_color"
                tools:text="Jules Bonnot" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/subject"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="?attr/conversation_list_item_subject_color"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Wheels arrive at 3pm flat. This is a somewhat longer message." />

        </LinearLayout>

        <LinearLayout
            android:orientation="vertical"
            android:gravity="end"
            android:layout_marginLeft="10dp"
            android:layout_marginStart="10dp"
            android:layout_marginRight="0dp"
            android:layout_marginEnd="0dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <TextView
                android:id="@id/date"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:drawablePadding="4dp"
                android:textSize="12sp"
                android:textColor="?attr/conversation_list_item_date_color"
                android:singleLine="true"
                tools:text="30 mins" />

            <LinearLayout
                android:orientation="horizontal"
                    android:minHeight="24dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/request_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingLeft="7dp"
                    android:paddingRight="7dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:textSize="12sp"
                    android:text="@string/chat_request_label"
                    android:textColor="@color/white"
                    android:background="@drawable/archived_indicator_background" />

                <TextView
                    android:id="@+id/archived_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingLeft="7dp"
                    android:paddingRight="7dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:textSize="12sp"
                    android:text="@string/chat_archived_label"
                    android:textColor="@color/white"
                    android:background="@drawable/archived_indicator_background" />

                <ImageView
                    android:id="@+id/delivery_indicator"
                    android:layout_marginTop="3dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical|end"
                    android:tint="?attr/conversation_list_item_date_color"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/unread_indicator"
                    android:layout_width="22dp"
                    android:layout_height="22dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <View
        android:id="@+id/item_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_alignParentBottom="true"
        android:layout_marginLeft="80dp"
        android:layout_marginStart="80dp"
        android:background="#12000000" />

</org.thoughtcrime.securesms.ConversationListItem>
